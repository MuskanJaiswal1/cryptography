# Environment Configuration Example
# Copy this file to .env and configure for your environment

# Data Storage Paths (optional - defaults to ./data/)
# DATA_DIR=/path/to/your/data/directory
# UPLOAD_FOLDER=/path/to/uploads
# ENCRYPTED_FOLDER=/path/to/encrypted
# KEY_FOLDER=/path/to/keys
# TEMP_FILES_FOLDER=/path/to/temp
# RAW_DATA_FOLDER=/path/to/raw_data
# RESTORED_FILES_FOLDER=/path/to/restored

# ML Model Configuration
# ML_MODEL_DIR=/path/to/ml/models
# ENABLE_ML_SELECTION=True

# Security
# SECRET_KEY=your-secret-key-here-change-in-production

# Flask Application
# DEBUG=False
# HOST=0.0.0.0
# PORT=5000

# For Production Deployment (e.g. AWS S3, Azure Blob)
# STORAGE_TYPE=cloud  # 'local' or 'cloud'
# CLOUD_BUCKET_NAME=your-bucket-name
# CLOUD_REGION=us-east-1
